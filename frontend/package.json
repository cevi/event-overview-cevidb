{
  "name": "eventoverview",
  "version": "1.0.21",
  "scripts": {
    "start": "ng serve",
    "start:int": "ng serve --configuration int",
    "start:prod": "ng serve --configuration prod",
    "start:fr": "ng serve --configuration fr-prod",
    "build": "ng build",
    "build:int": "ng build --configuration int",
    "build:prod": "ng build --configuration prod",
    "test": "ng test",
    "test:ci": "ng test --no-watch --coverage",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "prettier": "npx prettier --write .",
    "extract-i18n": "ng extract-i18n --output-path src/locale"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.1",
    "@angular/cdk": "22.0.1",
    "@angular/common": "22.0.1",
    "@angular/compiler": "22.0.1",
    "@angular/core": "22.0.1",
    "@angular/forms": "22.0.1",
    "@angular/localize": "22.0.1",
    "@angular/material": "22.0.1",
    "@angular/platform-browser": "22.0.1",
    "@angular/router": "22.0.1",
    "material-icons": "^1.13.14",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.1",
    "@angular/cli": "22.0.1",
    "@angular/compiler-cli": "22.0.1",
    "@eslint/js": "10.0.1",
    "@vitest/coverage-v8": "^4.0.8",
    "angular-eslint": "22.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "jsdom": "^29.1.1",
    "prettier": "3.8.4",
    "prettier-eslint": "17.0.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "^4.0.8"
  }
}
